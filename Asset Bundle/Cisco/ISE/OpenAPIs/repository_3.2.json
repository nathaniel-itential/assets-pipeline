          },
          "protocol": {
            "type": "string",
            "enum": [
              "CDROM",
              "DISK",
              "FTP",
              "HTTP",
              "HTTPS",
              "NFS",
              "SFTP",
              "TFTP"
            ]
          },
          "serverName": {
            "type": "string"
          }
        }
      }
    }
  }
}
