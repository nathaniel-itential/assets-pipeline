        "type": "object",
        "properties": {
          "success": {
            "$ref": "#/components/schemas/Message"
          },
          "version": {
            "type": "string",
            "example": "1.0.0"
          }
        }
      },
      "TFTP": {
        "title": "TFTP",
        "required": [
          "name",
          "path",
          "protocol",
          "serverName"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Repository name should be less than 80 characters and can contain alphanumeric, underscore, hyphen and dot characters.",
