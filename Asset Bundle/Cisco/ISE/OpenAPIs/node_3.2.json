            "type": "string",
            "example": "OtherTestNode"
          },
          "ipAddresses": {
            "type": "array",
            "example": [
              "10.0.0.1",
              "10.0.0.2"
            ],
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                }
              }
            }
          },
          "ipAddress": {
            "type": "string",
            "example": "10.0.0.3"
