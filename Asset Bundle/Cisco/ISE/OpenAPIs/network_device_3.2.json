  "info": {
    "title": "Cisco ISE \u2014 Network Devices",
    "description": "Cisco Identity Services Engine (ISE) API for managing network access devices (NADs) including AAA clients, device groups, and RADIUS/TACACS+ settings.\n\nAuthentication: HTTP Basic \u2014 Cisco ISE administrator username and password. Enable API access under Administration \u2192 System \u2192 Settings \u2192 API Settings.\n\nSource: https://developer.cisco.com/docs/identity-services-engine/",
    "version": "1.0.0"
  },
